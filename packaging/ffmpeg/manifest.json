  "required_capabilities": {
    "decoders": ["h264", "mpeg4", "hevc"],
    "parsers": ["h264", "mpeg4video", "hevc"],
    "encoders": ["png"],
    "demuxers": ["mov"],
    "muxers": ["image2"],
    "protocols": ["file"],
    "filters": ["trim", "setpts", "minterpolate", "scale", "crop", "format", "fps"]
